# API origin (port should match Nest; path /api/v1 is added in code if omitted)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Local `next build` only — omit on Vercel (production guard blocks loopback API).
NEXT_PUBLIC_ALLOW_LOCALHOST_API=1

# Mapbox - get free token at https://account.mapbox.com/access-tokens/
NEXT_PUBLIC_MAPBOX_TOKEN=
