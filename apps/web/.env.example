# Copy to .env.local
# Use API origin only, or full base including /api/v1 (both supported)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Optional: use only for local `next build` when NEXT_PUBLIC_API_URL is still localhost.
# Never set on Vercel production.
# NEXT_PUBLIC_ALLOW_LOCALHOST_API=1

NEXT_PUBLIC_MAPBOX_TOKEN=
