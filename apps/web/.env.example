# Copy to `.env.local` (local) or set in Vercel Project → Environment Variables.
# No code changes required between environments — only this value.

# API base URL for frontend calls.
NEXT_PUBLIC_API_URL=https://estatex-api-pgza.onrender.com/api/v1

# Alternative examples:
# NEXT_PUBLIC_API_URL=https://your-api.example.com/api/v1
# NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# Optional: proxy `/api/*` to Nest when using NEXT_PUBLIC_API_URL=/api
# API_BACKEND_ORIGIN=https://your-nest-host.example.com

# NEXT_PUBLIC_DEBUG_API=1

NEXT_PUBLIC_MAPBOX_TOKEN=

# Supabase (browser) — create bucket `properties` (public read) and Storage policies for anon/authenticated upload.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
