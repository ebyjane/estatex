# Copy to .env.local
#
# Local dev: omit NEXT_PUBLIC_API_URL — default is applied in apps/web/lib/api.ts (development → Nest on port 8000).
# Set only to override, e.g.:
# NEXT_PUBLIC_API_URL=https://your-api.example.com
# or same-origin API (Vercel-style):
# NEXT_PUBLIC_API_URL=/api
#
# Vercel production: NEXT_PUBLIC_API_URL=/api
# Vercel: proxy /api to Nest (see next.config.js rewrites)
# API_BACKEND_ORIGIN=https://your-nest-host.example.com

# Set to 1 to log NODE_ENV and API_BASE_URL from root layout
# NEXT_PUBLIC_DEBUG_API=1

NEXT_PUBLIC_MAPBOX_TOKEN=
