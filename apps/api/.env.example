# PostgreSQL — Supabase Transaction pooler (port 6543). Username must be postgres.<project-ref>, not "postgres".
# Example shape (use your project ref and password from Supabase Dashboard → Database):
# DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?sslmode=require
#
# Set the real DATABASE_URL on Render (or local .env); do not commit secrets.

# Optional: Supabase JS client (Storage, etc.) — use service role only on the server
# SUPABASE_URL=https://[PROJECT-REF].supabase.co
# SUPABASE_SERVICE_ROLE_KEY=

# JWT for API auth (change in production)
JWT_SECRET=change-me-in-production

# Optional: initial password when the default admin row is auto-created on first login (defaults to admin123)
# ADMIN_BOOTSTRAP_PASSWORD=

# Set to false to skip auto-inserting demo countries/properties when the DB has zero listings
# AUTO_DEMO_PROPERTIES=

# Schema sync is disabled in code (synchronize: false). Use migrations for schema changes.

# Pool size (serverless-friendly small pool)
# DB_POOL_MAX=10
