# PostgreSQL — prefer Supabase "Connection string" (URI) from Project Settings → Database
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# Optional: Supabase JS client (Storage, etc.) — use service role only on the server
# SUPABASE_URL=https://[PROJECT-REF].supabase.co
# SUPABASE_SERVICE_ROLE_KEY=

# JWT for API auth (change in production)
JWT_SECRET=change-me-in-production

# Optional: initial password when the default admin row is auto-created on first login (defaults to admin123)
# ADMIN_BOOTSTRAP_PASSWORD=

# Set to false to skip auto-inserting demo countries/properties when the DB has zero listings
# AUTO_DEMO_PROPERTIES=

# Schema sync: true once on empty DB, then false in production (use migrations)
# DATABASE_SYNC=true

# Pool size (serverless-friendly small pool)
# DB_POOL_MAX=10
