# Database
DB_HOST=localhost
DB_PORT=5434
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=real_estate

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:3002,http://127.0.0.1:3002

# SQLite (default): DB file at monorepo root real-estate.db when API cwd is apps/api
# DATABASE_PATH=C:\path\to\real-estate.db

# OpenAI (for AI descriptions & pricing)
OPENAI_API_KEY=sk-...

# FX API (optional - uses fallback rates if not set)
# FX_API_KEY=...

# Port (must match web NEXT_PUBLIC_API_URL)
PORT=8000

# Optional: require header x-demo-seed-secret when calling POST /api/v1/admin/seed in production
# ADMIN_SEED_SECRET=change-me
