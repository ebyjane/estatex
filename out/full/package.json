{
  "name": "real-estate-platform",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "start": "npm run seed:data && npm run dev",
    "start:all": "ts-node scripts/startup.ts",
    "dev": "turbo run dev",
    "dev:simple": "npm run dev:api & npm run dev:web",
    "seed:data": "npm run build -w @real-estate/shared && ts-node scripts/seed.ts",
    "seed:10k": "ts-node scripts/sqliteBulk10k.ts",
    "seed:india-rent": "npm run build -w @real-estate/shared && ts-node scripts/generateIndiaRentData.ts",
    "seed:admin": "ts-node scripts/seedAdmin.ts",
    "generate-data": "ts-node scripts/generateLargeDataset.ts",
    "add-images": "ts-node scripts/addPropertyImages.ts",
    "dev:api": "npm run dev -w @real-estate/api",
    "dev:web": "npm run dev -w @real-estate/web",
    "dev:web:clean": "npm run dev:clean -w @real-estate/web",
    "clean:web": "npm run clean -w @real-estate/web",
    "fix:longitudes": "node scripts/normalize-property-longitudes.cjs",
    "dev:mobile": "cd apps/mobile && npm install && npm run start",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down"
  },
  "devDependencies": {
    "@nestjs/platform-express": "^11.1.17",
    "@types/better-sqlite3": "^7.6.13",
    "@types/pg": "^8.18.0",
    "bcrypt": "^6.0.0",
    "pg": "^8.19.0",
    "ts-node": "^10.9.2",
    "turbo": "^2.0.0",
    "typescript": "^5.9.3"
  },
  "packageManager": "npm@10.2.0",
  "overrides": {
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "rxjs": "^7.8.2"
  }
}
