# Copy to .env and fill values

# PostgreSQL — required for API + `npm run seed:data` (see docs/SUPABASE.md)
# Local Docker: docker compose up -d postgres  →  host port 5434
# DATABASE_URL=postgresql://postgres:postgres@localhost:5434/real_estate

# --- Next.js (apps/web/.env.local or Vercel) ---
# NEXT_PUBLIC_API_URL=http://localhost:8000
# Production: https://your-api-host.example.com  OR  /api  (with rewrites to Nest)

# --- API (apps/api/.env) ---
# DATABASE_URL=postgresql://...
# JWT_SECRET=change-me

# Mapbox (for global map)
NEXT_PUBLIC_MAPBOX_TOKEN=pk....
